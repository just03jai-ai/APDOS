{
  "name": "apdos",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "apdos",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@apdos/artifacts": {
      "resolved": "packages/artifacts",
      "link": true
    },
    "packages/artifacts": {
      "name": "@apdos/artifacts",
      "version": "0.1.0",
      "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.5.0"
      }
    },
    "packages/artifacts/node_modules/@types/node": {
      "version": "22.19.19",
      "dev": true,
      "license": "MIT",
      "dependencies": {
        "undici-types": "~6.21.0"
      }
    },
    "packages/artifacts/node_modules/typescript": {
      "version": "5.9.3",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/artifacts/node_modules/undici-types": {
      "version": "6.21.0",
      "dev": true,
      "license": "MIT"
    }
  }
}
